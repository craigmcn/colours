{
    "name": "colours",
    "version": "3.0.0",
    "repository": "github:craigmcn/colours",
    "description": "Colour manipulator and contrast checker",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "build:netlify": "tsc -b && vite build --outDir=netlify && vite build --base=/colours/ --outDir=netlify/colours",
        "preview": "vite preview"
    },
    "dependencies": {
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-router-dom": "^7.5.0"
    },
    "devDependencies": {
        "@types/react": "^19.1.0",
        "@types/react-dom": "^19.1.0",
        "@vitejs/plugin-react": "^4.4.1",
        "sass": "^1.86.0",
        "typescript": "^5.8.2",
        "vite": "^6.3.1"
    },
    "keywords": [
        "wcag",
        "a11y",
        "accessibility",
        "color",
        "colour",
        "contrast",
        "check"
    ],
    "author": "Craig McNaughton",
    "license": "GPL-3.0-or-later"
}
